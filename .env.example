# ─── Discord OAuth2 ──────────────────────────────────────────────────────────
# Obtén estos valores en: https://discord.com/developers/applications
DISCORD_CLIENT_ID=tu_client_id_aqui
DISCORD_CLIENT_SECRET=tu_client_secret_aqui
DISCORD_GUILD_ID=id_de_tu_servidor_discord

# IDs de roles de Discord separados por coma que tendrán acceso de admin
ADMIN_ROLE_IDS=123456789,987654321

# ─── Sesión ───────────────────────────────────────────────────────────────────
# Clave secreta para firmar las cookies de sesión. Usa una cadena larga y aleatoria.
SESSION_SECRET=genera-una-clave-secreta-larga-y-aleatoria-aqui

# ─── URL base ─────────────────────────────────────────────────────────────────
# En desarrollo: http://localhost:3000
# En producción: https://tudominio.com
BASE_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Obtén estos valores en: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=tu_service_role_key_aqui
SUPABASE_ANON_KEY=tu_anon_key_aqui

# ─── Solo en desarrollo local ─────────────────────────────────────────────────
# Descomenta la siguiente línea si usas HTTP en local (no en producción)
# DISABLE_SECURE_COOKIE=true
