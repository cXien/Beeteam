{
  "name": "beeteam-web",
  "version": "3.0.0",
  "description": "BeeTeam Minecraft Server Website",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "lint": "eslint server.js config.js routes/ middleware/ db/ public/js/",
    "lint:backend": "eslint server.js config.js routes/ middleware/ db/",
    "lint:frontend": "eslint public/js/",
    "lint:fix": "eslint server.js config.js routes/ middleware/ db/ public/js/ --fix",
    "format": "prettier --write \"**/*.{js,css,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,css,json}\" --ignore-path .gitignore",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cookie-session": "^2.1.1",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-node": "^11.1.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*.js": ["eslint --fix", "prettier --write"],
    "*.{css,json}": ["prettier --write"]
  }
}
